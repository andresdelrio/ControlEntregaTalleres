# Variables configurables en Setup Node.js App de cPanel
NODE_ENV=production
PORT=3000
APP_BASE_PATH=/seguimiento-talleres

# Debe tener al menos 6 caracteres. Use un código largo y difícil de adivinar.
EDIT_ACCESS_CODE=cambie-este-codigo

DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_cpanel
DB_PASSWORD=contrasena_segura
DB_NAME=base_de_datos_cpanel
